# Copy to .env and fill in your values:
#   cp .env.example .env
# Then source before running scripts:
#   source .env

# Absolute path to your Obsidian vault directory.
# This is the folder that contains your .md notes.
# The LiveSync local database lives in .livesync/ inside this directory.
LIVESYNC_VAULT_PATH=/path/to/your/obsidian-vault

# Debounce window for the watcher in milliseconds (default: 3000).
# A burst of remote writes won't trigger more than one pull per window.
LIVESYNC_PULL_DEBOUNCE_MS=3000
